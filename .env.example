# Copiar como .env y completar los valores

# Generar con: docker run --rm php:8.3-cli php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
APP_KEY=base64:CAMBIA_ESTO

# IP o dominio del servidor
APP_URL=http://192.168.1.100
APP_PORT=80

# Base de datos
DB_DATABASE=expedientes_juridicos
DB_USERNAME=laravel
DB_PASSWORD=CAMBIA_ESTO_TAMBIEN
